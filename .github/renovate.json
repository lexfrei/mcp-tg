{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>lexfrei/renovate-config"],
  "rangeStrategy": "pin",
  "packageRules": [
    {
      "description": "Group all Go module updates into one PR",
      "matchManagers": ["gomod"],
      "groupName": "go modules",
      "groupSlug": "go-modules"
    },
    {
      "description": "Group all GitHub Actions updates into one PR",
      "matchManagers": ["github-actions"],
      "groupName": "github actions",
      "groupSlug": "github-actions"
    },
    {
      "description": "Pin the Go base image in the Containerfile using docker versioning",
      "matchManagers": ["dockerfile"],
      "matchPackageNames": ["docker.io/library/golang"],
      "versioning": "docker"
    }
  ]
}
